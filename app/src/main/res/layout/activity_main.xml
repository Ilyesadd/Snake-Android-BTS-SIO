<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0d0d0d"
    android:gravity="center_horizontal">

    <!-- Barre de score -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvScore"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SCORE: 0"
            android:textColor="#00ff88"
            android:textSize="18sp"
            android:fontFamily="monospace"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvBest"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BEST: 0"
            android:textColor="#00ccff"
            android:textSize="18sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:gravity="end"/>
    </LinearLayout>

    <!-- Zone de jeu : prend tout l'espace disponible -->
    <com.btssio.snake.SnakeView
        android:id="@+id/snakeView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Bouton démarrer / rejouer -->
    <Button
        android:id="@+id/btnStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="▶  DÉMARRER"
        android:textColor="#000000"
        android:backgroundTint="#00ff88"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:paddingHorizontal="32dp"/>

    <!-- D-Pad -->
    <GridLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:rowCount="2"
        android:columnCount="3">

        <Button
            android:id="@+id/btnUp"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_column="1"
            android:layout_row="0"
            android:text="▲"
            android:textSize="20sp"
            android:backgroundTint="#1a1a2e"
            android:textColor="#e0e0e0"/>

        <Button
            android:id="@+id/btnLeft"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_column="0"
            android:layout_row="1"
            android:text="◄"
            android:textSize="20sp"
            android:backgroundTint="#1a1a2e"
            android:textColor="#e0e0e0"/>

        <Button
            android:id="@+id/btnDown"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_column="1"
            android:layout_row="1"
            android:text="▼"
            android:textSize="20sp"
            android:backgroundTint="#1a1a2e"
            android:textColor="#e0e0e0"/>

        <Button
            android:id="@+id/btnRight"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_column="2"
            android:layout_row="1"
            android:text="►"
            android:textSize="20sp"
            android:backgroundTint="#1a1a2e"
            android:textColor="#e0e0e0"/>
    </GridLayout>

</LinearLayout>
